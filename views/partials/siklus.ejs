<!-- Hero Banner -->
<div class="bg-gradient-to-br from-[#1e40af] to-[#3b82f6] rounded-2xl p-6 lg:p-8 mb-6 text-white shadow-lg">
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h2 class="text-xl lg:text-2xl font-bold tracking-tight">Sirkulasi Menu</h2>
      </div>
      <p class="text-white/80 text-sm max-w-xl">Rencanakan menu bergizi untuk setiap siklus — atur menu harian, pantau kandungan gizi, dan cetak laporan.</p>
    </div>
    <button onclick="openSiklusForm()" class="inline-flex items-center gap-2 bg-white text-[#1e40af] px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-white/90 transition-all shadow-sm shrink-0">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Siklus Baru
    </button>
  </div>
</div>

<!-- Quick Stats -->
<div id="siklus-stats" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6 hidden">
  <div class="bg-white border border-stone-200 rounded-xl p-4">
    <div class="text-xs uppercase tracking-wider text-stone-500 font-medium">Total Siklus</div>
    <div class="text-2xl font-bold text-stone-800 mt-1" id="stat-total">0</div>
  </div>
  <div class="bg-white border border-stone-200 rounded-xl p-4">
    <div class="text-xs uppercase tracking-wider text-stone-500 font-medium">Aktif</div>
    <div class="text-2xl font-bold text-green-700 mt-1" id="stat-aktif">0</div>
  </div>
  <div class="bg-white border border-stone-200 rounded-xl p-4">
    <div class="text-xs uppercase tracking-wider text-stone-500 font-medium">Draft</div>
    <div class="text-2xl font-bold text-stone-500 mt-1" id="stat-draft">0</div>
  </div>
  <div class="bg-white border border-stone-200 rounded-xl p-4">
    <div class="text-xs uppercase tracking-wider text-stone-500 font-medium">Menu Terpakai</div>
    <div class="text-2xl font-bold text-[#1e40af] mt-1" id="stat-menu">0</div>
  </div>
</div>

<!-- Search & Filter Bar -->
<div class="flex flex-wrap items-center justify-between gap-3 mb-4">
  <div class="relative flex-1 min-w-[200px] max-w-xs">
    <svg class="absolute left-3 top-2.5 w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    <input type="text" id="siklus-search" placeholder="Cari siklus..." autocomplete="off"
      class="pl-10 pr-4 py-2.5 border border-stone-200 rounded-xl text-sm w-full focus:outline-none focus:ring-2 focus:ring-[#1e40af]/20 focus:border-[#1e40af] bg-white transition" />
  </div>
  <div class="flex items-center gap-2">
    <select id="siklus-filter-status" class="px-3 py-2.5 border border-stone-200 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-[#1e40af]/20">
      <option value="">Semua Status</option>
      <option value="Aktif">Aktif</option>
      <option value="Draft">Draft</option>
      <option value="Arsip">Arsip</option>
    </select>
  </div>
</div>

<!-- Siklus Grid -->
<div id="siklus-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4"></div>

<!-- Siklus Detail Area -->
<div id="siklus-detail" class="mt-6"></div>
