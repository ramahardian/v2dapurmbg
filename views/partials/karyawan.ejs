<div class="flex flex-wrap gap-2 mb-4">
  <button id="add-karyawan-btn" onclick="openKaryawanForm()" class="bg-[#1e40af] hover:bg-[#1d4ed8] text-white px-4 py-2 rounded-md text-sm font-medium">+ Tambah Karyawan</button>
  <div class="relative flex-1 min-w-[140px]">
    <input type="text" id="karyawan-search-input" placeholder="Cari karyawan..." autocomplete="off"
      class="pl-10 pr-4 py-2 border border-stone-200 rounded-md text-sm w-full focus:outline-none focus:border-[#1e40af]">
    <svg class="absolute left-3 top-2.5 w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
  </div>
</div>
<div class="bg-white border border-stone-200 rounded-lg overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-stone-50">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-semibold uppercase">Nama</th>
          <th class="text-left px-4 py-3 text-xs font-semibold uppercase">NIK</th>
          <th class="text-left px-4 py-3 text-xs font-semibold uppercase">Jabatan</th>
          <th class="text-left px-4 py-3 text-xs font-semibold uppercase">Departemen</th>
          <th class="text-right px-4 py-3 text-xs font-semibold uppercase">Gaji Pokok</th>
          <th class="text-left px-4 py-3 text-xs font-semibold uppercase">Status</th>
          <th class="text-right px-4 py-3 text-xs font-semibold uppercase">Aksi</th>
        </tr>
      </thead>
      <tbody id="karyawan-table-body">
        <tr><td colspan="7" class="text-center py-12 text-stone-400">Memuat data karyawan...</td></tr>
      </tbody>
    </table>
  </div>
</div>
<div id="karyawan-pagination" class="flex items-center gap-2 mt-4"></div>
<div id="karyawan-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-lg max-h-[90vh] overflow-hidden flex flex-col">
    <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-stone-200 flex justify-between items-center">
      <h3 id="karyawan-modal-title" class="text-base font-bold">Tambah Karyawan</h3>
      <button onclick="closeModal('karyawan-modal')" class="text-stone-400 hover:text-stone-700 text-xl">×</button>
    </div>
    <div class="p-4 sm:p-6 overflow-y-auto flex-1">
      <form id="karyawan-form" class="space-y-4">
        <input type="hidden" id="karyawan-id" />
        <div>
          <label class="text-sm text-stone-700">Nama Lengkap <span class="text-red-500">*</span></label>
          <input id="karyawan-nama" type="text" required class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" />
        </div>
        <div>
          <label class="text-sm text-stone-700">NIK</label>
          <input id="karyawan-nik" type="text" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          <div>
            <label class="text-sm text-stone-700">Jabatan</label>
            <select id="karyawan-jabatan" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md"></select>
          </div>
          <div>
            <label class="text-sm text-stone-700">Departemen</label>
            <select id="karyawan-departemen" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md"></select>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          <div>
            <label class="text-sm text-stone-700">Gaji Pokok (Rp)</label>
            <input id="karyawan-gaji" type="number" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" />
          </div>
          <div>
            <label class="text-sm text-stone-700">Status</label>
            <select id="karyawan-status" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md">
              <option value="Aktif">Aktif</option>
              <option value="Cuti">Cuti</option>
              <option value="Resign">Resign</option>
            </select>
          </div>
        </div>
        <div>
          <label class="text-sm text-stone-700">Tanggal Masuk</label>
          <input id="karyawan-masuk" type="date" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          <div>
            <label class="text-sm text-stone-700">Email</label>
            <input id="karyawan-email" type="email" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" placeholder="email@example.com" />
          </div>
          <div>
            <label class="text-sm text-stone-700">Telepon</label>
            <input id="karyawan-telepon" type="text" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" placeholder="08xxxxxxxxxx" />
          </div>
        </div>
        <div>
          <label class="text-sm text-stone-700">Alamat</label>
          <textarea id="karyawan-alamat" rows="2" class="mt-1 w-full px-3 py-2 border border-stone-200 rounded-md" placeholder="Alamat lengkap"></textarea>
        </div>
        <div>
          <label class="text-sm text-stone-700">Foto Profil</label>
          <div class="flex items-center gap-4 mt-1">
            <div id="karyawan-photo-preview" class="w-16 h-16 rounded-full bg-stone-100 flex items-center justify-center overflow-hidden shrink-0">
              <svg class="w-6 h-6 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <div class="flex flex-col gap-1">
              <input id="karyawan-photo-input" type="file" accept="image/*" class="text-sm text-stone-600 file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-[#1e40af] file:text-white hover:file:bg-[#1d4ed8]" />
              <button type="button" id="karyawan-photo-hapus" class="text-xs text-red-600 text-left hover:underline hidden">Hapus foto</button>
            </div>
          </div>
        </div>
      </form>
    </div>
    <div class="px-4 sm:px-6 py-3 border-t border-stone-200 flex justify-end gap-2">
      <button onclick="closeModal('karyawan-modal')" class="px-4 py-2 text-sm text-stone-600 hover:bg-stone-100 rounded">Batal</button>
      <button id="karyawan-save" class="px-4 py-2 text-sm bg-[#1e40af] hover:bg-[#1d4ed8] text-white rounded font-medium">Simpan</button>
    </div>
  </div>
</div>
