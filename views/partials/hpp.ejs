<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="bg-white border border-stone-200 rounded-lg p-6">
    <div class="font-bold mb-4 flex items-center gap-2"><svg class="w-5 h-5 text-stone-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="8" y2="10.01"/><line x1="12" y1="10" x2="12" y2="10.01"/><line x1="16" y1="10" x2="16" y2="10.01"/><line x1="8" y1="14" x2="8" y2="14.01"/><line x1="12" y1="14" x2="12" y2="14.01"/><line x1="16" y1="14" x2="16" y2="14.01"/><line x1="8" y1="18" x2="8" y2="18.01"/><line x1="12" y1="18" x2="12" y2="18.01"/><line x1="16" y1="18" x2="16" y2="18.01"/></svg> Input Perhitungan</div>
    <div class="space-y-3">
      <div>
        <label class="text-sm">Menu</label>
        <select id="hpp-menu" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md">
          <option value="">— Pilih —</option>
          <% if (menus) { %>
            <% menus.forEach(function(m) { %>
              <option value="<%= m.id %>"><%= m.nama %></option>
            <% }); %>
          <% } %>
        </select>
      </div>
      <div>
        <label class="text-sm">Jumlah Porsi</label>
        <input id="hpp-porsi" type="number" value="100" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md mono" />
      </div>
      <div>
        <label class="text-sm">Biaya Tenaga Kerja (IDR)</label>
        <input id="hpp-tk" type="number" value="0" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md mono" />
      </div>
      <div>
        <label class="text-sm">Biaya Overhead (IDR)</label>
        <input id="hpp-oh" type="number" value="0" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md mono" />
      </div>
      <button onclick="calcHPP()" class="w-full bg-[#1e40af] hover:bg-[#1d4ed8] text-white py-2 rounded-md font-medium">Hitung HPP</button>
    </div>
  </div>
  <div id="hpp-result" class="lg:col-span-2">
    <div class="bg-white border border-stone-200 rounded-lg p-12 text-center">
      <svg class="w-16 h-16 text-stone-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="8" y2="10.01"/><line x1="12" y1="10" x2="12" y2="10.01"/><line x1="16" y1="10" x2="16" y2="10.01"/><line x1="8" y1="14" x2="8" y2="14.01"/><line x1="12" y1="14" x2="12" y2="14.01"/><line x1="16" y1="14" x2="16" y2="14.01"/><line x1="8" y1="18" x2="8" y2="18.01"/><line x1="12" y1="18" x2="12" y2="18.01"/><line x1="16" y1="18" x2="16" y2="18.01"/></svg>
      <p class="text-stone-400 text-sm">Pilih menu dan klik <strong>Hitung HPP</strong></p>
    </div>
  </div>
</div>
