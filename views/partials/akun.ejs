<div class="max-w-100 mx-auto space-y-6">
  <div class="bg-white border border-stone-200 rounded-xl overflow-hidden">
    <div class="px-6 py-4 border-b border-stone-100">
      <h3 class="font-bold text-base">Foto Profil</h3>
    </div>
    <div class="p-6 flex items-center gap-6">
      <div class="relative shrink-0">
        <div id="foto-preview" class="w-24 h-24 rounded-full bg-stone-100 border-2 border-dashed border-stone-300 flex items-center justify-center text-stone-400 text-3xl font-bold overflow-hidden">
          <% if (user.foto) { %>
            <img src="<%= user.foto %>" class="w-full h-full object-cover" />
          <% } else { %>
            <span id="foto-initials"><%= (user.nama || '').split(' ').map(w => w[0]).filter(Boolean).slice(0, 2).join('').toUpperCase() || '?' %></span>
          <% } %>
        </div>
        <label for="foto-input" class="absolute -bottom-1 -right-1 w-8 h-8 bg-[#1e40af] text-white rounded-full flex items-center justify-center cursor-pointer hover:bg-[#1d4ed8] shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
        </label>
        <input id="foto-input" type="file" accept="image/png,image/jpeg,image/gif,image/webp" class="hidden" />
      </div>
      <div class="text-sm text-stone-500">
        <p class="font-medium text-stone-700">Upload Foto</p>
        <p>Format: PNG, JPG, GIF, WebP. Maks 2MB.</p>
        <button id="btn-hapus-foto" class="text-red-600 hover:text-red-700 text-xs font-medium mt-1 <%= user.foto ? '' : 'hidden' %>">Hapus foto</button>
      </div>
    </div>
  </div>

  <div class="bg-white border border-stone-200 rounded-xl overflow-hidden">
    <div class="px-6 py-4 border-b border-stone-100">
      <h3 class="font-bold text-base">Profil Saya</h3>
    </div>
    <div class="p-6 space-y-4">
      <div>
        <label class="text-sm font-medium text-stone-700">Nama Lengkap</label>
        <input id="akun-nama" value="<%= user.nama %>" class="mt-1 w-full h-11 px-4 border border-stone-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-400 text-sm" />
      </div>
      <div>
        <label class="text-sm font-medium text-stone-700">Email</label>
        <input id="akun-email" type="email" value="<%= user.email %>" class="mt-1 w-full h-11 px-4 border border-stone-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-400 text-sm" />
      </div>
      <div>
        <label class="text-sm font-medium text-stone-700">Role</label>
        <input value="<%= user.role.replace('_', ' ') %>" disabled class="mt-1 w-full h-11 px-4 border border-stone-200 rounded-xl bg-stone-50 text-stone-500 text-sm capitalize" />
      </div>
      <div class="pt-2">
        <button id="btn-simpan-profil" class="bg-[#1e40af] hover:bg-[#1d4ed8] text-white px-6 py-2.5 rounded-xl text-sm font-medium transition-colors">Simpan Profil</button>
      </div>
    </div>
  </div>

  <div class="bg-white border border-stone-200 rounded-xl overflow-hidden">
    <div class="px-6 py-4 border-b border-stone-100">
      <h3 class="font-bold text-base">Ganti Kata Sandi</h3>
    </div>
    <div class="p-6 space-y-4">
      <div>
        <label class="text-sm font-medium text-stone-700">Password Lama</label>
        <input id="akun-pass-lama" type="password" placeholder="Masukkan password saat ini" class="mt-1 w-full h-11 px-4 border border-stone-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-400 text-sm" />
      </div>
      <div>
        <label class="text-sm font-medium text-stone-700">Password Baru</label>
        <input id="akun-pass-baru" type="password" placeholder="Minimal 6 karakter" class="mt-1 w-full h-11 px-4 border border-stone-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-400 text-sm" />
      </div>
      <div class="pt-2">
        <button id="btn-ganti-password" class="bg-stone-700 hover:bg-stone-800 text-white px-6 py-2.5 rounded-xl text-sm font-medium transition-colors">Ganti Password</button>
      </div>
    </div>
  </div>
</div>