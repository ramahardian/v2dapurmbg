<div class="mb-4 space-y-2">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2">
    <select id="pay-filter-karyawan" class="h-10 px-3 border border-stone-200 rounded-md text-sm">
      <option value="">Semua Karyawan</option>
    </select>
    <div class="relative">
      <span class="absolute -top-2 left-2 bg-white px-1 text-xs text-stone-500">Periode</span>
      <input id="pay-filter-periode" type="date" class="h-10 px-3 border border-stone-200 rounded-md text-sm w-full" />
    </div>
    <select id="pay-filter-status" class="h-10 px-3 border border-stone-200 rounded-md text-sm">
      <option value="">Semua Status</option>
      <option>Draft</option><option>Disetujui</option><option>Dibayar</option>
    </select>
    <div class="flex gap-2">
      <button onclick="loadPayroll()" class="flex-1 px-4 py-2 border border-stone-200 rounded-md text-sm whitespace-nowrap hover:bg-stone-50">Filter</button>
      <button onclick="openPayrollForm()" class="flex-1 bg-[#1e40af] hover:bg-[#1d4ed8] text-white px-4 py-2 rounded-md text-sm font-medium whitespace-nowrap">+ Tambah</button>
    </div>
  </div>
</div>
<div class="bg-white border border-stone-200 rounded-lg overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-stone-50">
        <tr>
          <th class="text-left px-4 py-3 text-xs font-semibold uppercase">Bulan/Tahun</th>
          <th class="text-left px-4 py-3 text-xs font-semibold uppercase">Nama Karyawan</th>
          <th class="text-left px-4 py-3 text-xs font-semibold uppercase">Jabatan</th>
          <th class="text-right px-4 py-3 text-xs font-semibold uppercase">Gaji Pokok</th>
          <th class="text-right px-4 py-3 text-xs font-semibold uppercase">Tunjangan</th>
          <th class="text-right px-4 py-3 text-xs font-semibold uppercase">Potongan</th>
          <th class="text-right px-4 py-3 text-xs font-semibold uppercase">Total Gaji</th>
          <th class="text-center px-4 py-3 text-xs font-semibold uppercase">Status</th>
          <th class="text-right px-4 py-3 text-xs font-semibold uppercase">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <tr><td colspan="9" class="text-center py-12 text-stone-400">Memuat data payroll...</td></tr>
      </tbody>
    </table>
  </div>
</div>
<div id="payroll-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-lg max-h-[90vh] overflow-hidden flex flex-col">
    <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-stone-200 flex justify-between items-center">
      <h3 id="payroll-modal-title" class="text-base font-bold">Tambah Payroll</h3>
      <button onclick="closeModal('payroll-modal')" class="text-stone-400 hover:text-stone-700 text-xl">×</button>
    </div>
    <div class="p-4 sm:p-6 overflow-y-auto flex-1">
      <form id="payroll-form" class="space-y-4">
        <input type="hidden" id="payroll-id" />
        <div>
          <label class="text-sm text-stone-700">Karyawan <span class="text-red-500">*</span></label>
          <select id="payroll-karyawan" required class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md"></select>
        </div>
        <div>
          <label class="text-sm text-stone-700">Periode <span class="text-red-500">*</span></label>
          <input id="payroll-periode" type="date" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          <div>
            <label class="text-sm text-stone-700">Gaji Pokok (Rp)</label>
            <input id="payroll-gaji" type="number" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" />
          </div>
          <div>
            <label class="text-sm text-stone-700">Tunjangan (Rp)</label>
            <input id="payroll-tunjangan" type="number" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" />
          </div>
          <div>
            <label class="text-sm text-stone-700">Potongan (Rp)</label>
            <input id="payroll-potongan" type="number" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md" />
          </div>
        </div>
        <div>
          <label class="text-sm text-stone-700">Status</label>
          <select id="payroll-status" class="mt-1 w-full h-10 px-3 border border-stone-200 rounded-md">
            <option>Draft</option><option>Disetujui</option><option>Dibayar</option>
          </select>
        </div>
      </form>
    </div>
    <div class="px-4 sm:px-6 py-3 border-t border-stone-200 flex justify-end gap-2">
      <button onclick="closeModal('payroll-modal')" class="px-4 py-2 text-sm text-stone-600 hover:bg-stone-100 rounded">Batal</button>
      <button id="payroll-save" class="px-4 py-2 text-sm bg-[#1e40af] hover:bg-[#1d4ed8] text-white rounded font-medium">Simpan</button>
    </div>
  </div>
</div>
