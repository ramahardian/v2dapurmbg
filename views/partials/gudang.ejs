<div class="flex flex-wrap justify-between gap-2 mb-4">
  <div class="relative">
    <input type="text" id="gudang-search" placeholder="Cari..." value=""
      class="pl-10 pr-4 py-2 border border-stone-200 rounded-md text-sm w-48 focus:outline-none focus:border-[#1e40af]">
    <svg class="absolute left-3 top-2.5 w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
  </div>
  <div class="flex gap-2">
    <button onclick="openStokForm('masuk')" class="border border-blue-300 text-blue-700 hover:bg-blue-50 px-4 py-2 rounded-md text-sm font-medium">↓ Barang Masuk</button>
    <button onclick="openStokForm('keluar')" class="border border-orange-300 text-orange-700 hover:bg-orange-50 px-4 py-2 rounded-md text-sm font-medium">↑ Barang Keluar</button>
  </div>
</div>
<div class="overflow-x-auto -mx-4 sm:mx-0 mb-4">
  <div class="flex px-4 sm:px-0 min-w-max sm:min-w-0 border-b border-stone-200" style="gap:2px">
    <button onclick="showGudang('stok')" id="tab-stok" class="px-3 sm:px-5 py-2 sm:py-2.5 text-xs sm:text-sm font-medium rounded-t-lg border border-b-0 border-stone-200 bg-white text-blue-600 -mb-px relative z-[2] shadow-sm">Stok Saat Ini</button>
    <button onclick="showGudang('masuk')" id="tab-masuk" class="px-3 sm:px-5 py-2 sm:py-2.5 text-xs sm:text-sm font-medium rounded-t-lg border border-b-0 border-stone-200 bg-emerald-100 text-emerald-700 hover:bg-emerald-200 -mb-px">Riwayat Masuk</button>
    <button onclick="showGudang('keluar')" id="tab-keluar" class="px-3 sm:px-5 py-2 sm:py-2.5 text-xs sm:text-sm font-medium rounded-t-lg border border-b-0 border-stone-200 bg-orange-100 text-orange-700 hover:bg-orange-200 -mb-px">Riwayat Keluar</button>
  </div>
</div>
<div id="gudang-content" class="mb-3"></div>
<div id="gudang-pagination" class="flex items-center justify-between"></div>
