<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <title>Masuk — Dapur Sukaluyu</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;700;800&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'IBM Plex Sans', sans-serif; }
    h1,h2,h3 { font-family: 'Plus Jakarta Sans', sans-serif; }
  </style>
</head>
<body class="min-h-screen flex bg-stone-50">
  <div class="w-full lg:w-1/2 flex items-center justify-center p-8">
    <div class="w-full max-w-md">
      <div class="flex items-center gap-3 mb-10">
        <div class="h-11 w-11 rounded-lg bg-[#1e40af] flex items-center justify-center text-white font-bold">MBG</div>
        <div>
          <div class="font-bold text-lg">Dapur Sukaluyu</div>
          <div class="text-xs text-stone-500">SaaS Operasional & Akuntansi</div>
        </div>
      </div>
      <h1 class="text-3xl font-bold mb-2">Masuk ke Dashboard</h1>
      <p class="text-stone-500 mb-8 text-sm">Kelola operasional dapur Makan Bergizi Gratis dengan presisi.</p>
      <form id="login-form" class="space-y-4">
        <div>
          <label class="text-sm text-stone-700">Email</label>
          <input id="email" type="email" required value="admin@mbg.id" class="mt-1 w-full h-11 px-3 border border-stone-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#1e40af]" />
        </div>
        <div>
          <label class="text-sm text-stone-700">Kata Sandi</label>
          <input id="password" type="password" required value="admin123" class="mt-1 w-full h-11 px-3 border border-stone-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#1e40af]" />
        </div>
        <div id="err" class="text-sm text-red-700 hidden bg-red-50 border border-red-200 p-2 rounded"></div>
        <button class="w-full h-11 bg-[#1e40af] hover:bg-[#1d4ed8] text-white rounded-md font-medium">Masuk</button>
      </form>
     
    </div>
  </div>
  <div class="hidden lg:block lg:w-1/2 bg-[#1e40af] relative">
    <div class="absolute inset-0 flex items-end p-10 text-white">
      <div>
        <h2 class="text-3xl font-bold mb-2">Gizi untuk Generasi </h2>
        <p class="text-white/80 text-sm">Manajemen operasional dapur Sukaluyu</p>
      </div>
    </div>
  </div>
  <script>
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const err = document.getElementById('err'); err.classList.add('hidden');
      const r = await fetch('/api/auth/login', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ email: email.value, password: password.value }),
      });
      const data = await r.json();
      if (!r.ok) { err.textContent = data.error || 'Gagal'; err.classList.remove('hidden'); return; }
      location.href = '/';
    });
  </script>
</body>
</html>
