<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Masuk — Dapur Sukaluyu</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;700;800&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'IBM Plex Sans', sans-serif; }
    h1,h2,h3 { font-family: 'Plus Jakarta Sans', sans-serif; }
    .gradient-bg { background: linear-gradient(135deg, #1e40af 0%, #3b82f6 50%, #06b6d4 100%); }
    .card-shadow { box-shadow: 0 20px 60px -15px rgba(0,0,0,0.15); }
  </style>
</head>
<body class="min-h-screen flex gradient-bg">
  <div class="hidden lg:flex lg:w-1/2 relative items-center justify-center p-12">
    <div class="text-center max-w-md">
      <div class="w-20 h-20 mx-auto mb-6 bg-white rounded-2xl flex items-center justify-center shadow-lg overflow-hidden p-1">
        <img src="/asset/logo.png" alt="Dapur Sukaluyu" class="w-full h-full object-contain" />
      </div>
      <h2 class="text-4xl font-bold text-white mb-4">Dapur Sukaluyu</h2>
      <p class="text-white/70 text-lg leading-relaxed">Platform manajemen operasional dapur Makan Bergizi Gratis — kelola menu, bahan baku, produksi, distribusi, dan akuntansi dalam satu tempat.</p>
      <div class="grid grid-cols-3 gap-4 mt-10 text-center">
        <div class="bg-white/10 backdrop-blur rounded-xl p-4">
          <div class="text-2xl font-bold text-white">1000+</div>
          <div class="text-xs text-white/60 mt-1">Porsi/Hari</div>
        </div>
        <div class="bg-white/10 backdrop-blur rounded-xl p-4">
          <div class="text-2xl font-bold text-white">39</div>
          <div class="text-xs text-white/60 mt-1">Menu Gizi</div>
        </div>
        <div class="bg-white/10 backdrop-blur rounded-xl p-4">
          <div class="text-2xl font-bold text-white">5</div>
          <div class="text-xs text-white/60 mt-1">Kategori</div>
        </div>
      </div>
    </div>
  </div>
  <div class="w-full lg:w-1/2 flex items-center justify-center p-4 sm:p-8">
    <div class="w-full max-w-md bg-white rounded-2xl card-shadow p-6 sm:p-8">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-10 w-10 rounded-xl overflow-hidden shadow-sm">
          <img src="/asset/logo.png" alt="Dapur Sukaluyu" class="w-full h-full object-cover" />
        </div>
        <div>
          <div class="font-bold text-base text-stone-800">Dapur Sukaluyu</div>
        </div>
      </div>
      <h1 class="text-2xl font-bold text-stone-800 mb-1">Selamat Datang</h1>
      <p class="text-sm text-stone-500 mb-6">Masuk ke dashboard untuk melanjutkan.</p>
      <form id="login-form" class="space-y-4">
        <div>
          <label class="text-sm font-medium text-stone-700">Email</label>
          <div class="relative mt-1">
            <svg class="absolute left-3 top-3 w-5 h-5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input id="email" type="email" required value="admin@sukaluyu.id" placeholder="nama@email.com" class="w-full h-11 pl-10 pr-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#1e40af]/20 focus:border-[#1e40af] transition" />
          </div>
        </div>
        <div>
          <label class="text-sm font-medium text-stone-700">Kata Sandi</label>
          <div class="relative mt-1">
            <svg class="absolute left-3 top-3 w-5 h-5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input id="password" type="password" required value="admin123" placeholder="Kata sandi" class="w-full h-11 pl-10 pr-10 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#1e40af]/20 focus:border-[#1e40af] transition" />
            <button type="button" id="toggle-pass" class="absolute right-3 top-3 text-stone-400 hover:text-stone-600" tabindex="-1">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        <div id="err" class="text-sm text-red-700 hidden bg-red-50 border border-red-200 p-3 rounded-xl flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span id="err-text"></span>
        </div>
        <button class="w-full h-11 bg-gradient-to-r from-[#1e40af] to-[#3b82f6] hover:from-[#1d4ed8] hover:to-[#2563eb] text-white rounded-xl font-medium text-sm transition shadow-md hover:shadow-lg flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          Masuk
        </button>
      </form>
      <div class="mt-6 pt-6 border-t border-stone-100 text-center">
        <p class="text-xs text-stone-400">Dapur Sukaluyu &mdash; Sistem Manajemen Operasional</p>
      </div>
    </div>
  </div>
  <script>
    // Toggle password visibility
    document.getElementById('toggle-pass').addEventListener('click', function() {
      const pwd = document.getElementById('password');
      const isPass = pwd.getAttribute('type') === 'password';
      pwd.setAttribute('type', isPass ? 'text' : 'password');
      this.innerHTML = isPass
        ? '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>'
        : '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    });
    // Login submit
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const err = document.getElementById('err'); err.classList.add('hidden');
      try {
        const r = await fetch('/api/auth/login', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ email: document.getElementById('email').value, password: document.getElementById('password').value }),
        });
        let data;
        try { data = await r.json(); } catch {
          document.getElementById('err-text').textContent = 'Respons tidak valid dari server'; err.classList.remove('hidden'); return;
        }
        if (!r.ok) { document.getElementById('err-text').textContent = data.error || 'Gagal'; err.classList.remove('hidden'); return; }
        location.href = '/';
      } catch (e) {
        console.error('Login error:', e);
        document.getElementById('err-text').textContent = 'Gagal terhubung ke server';
        err.classList.remove('hidden');
      }
    });
  </script>
</body>
</html>
